# SMART on FHIR — public sandbox (no credentials needed for prototype)
# All NEXT_PUBLIC_SMART_* vars have sensible defaults; only override if needed.
NEXT_PUBLIC_SMART_ISS=https://launch.smarthealthit.org/v/r4/fhir
NEXT_PUBLIC_SMART_CLIENT_ID=demo_client
# On Vercel, set this to https://<your-deployment>.vercel.app/api/auth/callback
# Leave unset locally — the app will derive it from the request origin automatically.
NEXT_PUBLIC_SMART_REDIRECT_URI=http://localhost:3001/api/auth/callback
NEXT_PUBLIC_SMART_SCOPE=openid fhirUser launch/patient patient/*.read

# iron-session encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-32-plus-random-chars-for-iron-session-encryption!!

# AI — prefer Groq (free) over Anthropic
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Cross-app links (optional — defaults to localhost)
NEXT_PUBLIC_QUALITY_PORTAL_URL=http://localhost:3002
