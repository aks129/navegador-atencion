# ── Quality Portal — environment variables ────────────────────────────────────
# Copy this file to .env.local and fill in real values for local development.
# On Vercel, set each variable in the project's Environment Variables settings.

# ── Auth (demo gate) ──────────────────────────────────────────────────────────
# Password that users type on /login
# Default if unset: gigidemo
PORTAL_AUTH_PASSWORD=gigidemo

# Token stored in the qp-auth cookie and checked by middleware
# Default if unset: gigi-demo-2024
PORTAL_AUTH_TOKEN=gigi-demo-2024

# ── Cross-app links ───────────────────────────────────────────────────────────
# URL of the Care Navigator app — shown in the header "← Care Navigator" link
# On Vercel, set to https://<care-navigator-deployment>.vercel.app
NEXT_PUBLIC_CARE_NAVIGATOR_URL=http://localhost:3001
